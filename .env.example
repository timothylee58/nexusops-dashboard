# Copy to .env for local overrides (optional).
# Production Docker image sets VITE_OFFLINE_FEED=false at build time.

# Use live API in production builds (required when not using Docker build).
# VITE_OFFLINE_FEED=false

# Comma-separated browser origins for CORS when UI and API differ.
# MOCK_API_CORS=http://localhost:8080

# API listen port (Express). AWS App Runner injects PORT.
# PORT=8080
